"40"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">select item_id, item_type, count(chunk_text)
from embeddings
group by item_id, item_type;

select e.item_id, v.channel_name, v.title, count(e.chunk_text)
from embeddings e
join videos v on v.id = e.item_id
where v.title like 'Effective%'
group by e.item_id, v.channel_name, v.title
order by 4 desc;

select * from articles where title like 'what%';</sql><current_tab id="0"/></tab_sql></sqlb_project>
